# ── MongoDB Atlas ─────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://username:password@argus-cluster.xxxxx.mongodb.net/argus?retryWrites=true&w=majority&appName=argus-cluster

# ── Google Earth Engine ───────────────────────────────────────────
GEE_PROJECT=your-gee-project-id

# ── Satellite data (fallback if not using GEE) ────────────────────
COPERNICUS_USER=
COPERNICUS_PASSWORD=
EARTHDATA_TOKEN=
ECMWF_API_KEY=

# ── LLM (Groq — free tier) ────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Gas & carbon market prices ────────────────────────────────────
GAS_PRICE_USD_PER_MMBTU=2.80
CARBON_PRICE_USD_PER_TON=15.0